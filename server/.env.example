## MongoDB Atlas connection string (preferred)
# MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority"

## If your URI doesn't include /<db>, set this explicitly (recommended)
# MONGODB_DB_NAME="chatdb"

## Allowed frontend origins (comma-separated). Add your Vercel domain here.
# CLIENT_ORIGINS="http://localhost:3000,http://localhost:3001,https://<your-app>.vercel.app"

## Backwards-compatible name (optional)
# MONGO_URI=""

## Server port (optional)
# PORT=5001

